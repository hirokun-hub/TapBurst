{
  "sourceLanguage" : "en",
  "strings" : {
    "%@, %@" : {
      "comment" : "A static text element that combines the score and the title of the achievement to provide a single, descriptive label for accessibility. The first argument is the string “results.score”. The second argument is the string “a11y.results.title_label”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "The main content of the game HUD, displaying the player's score and the remaining time. The score is presented in a large, bold font, while the time is shown in a smaller, lighter font.",
      "isCommentAutoGenerated" : true
    },
    "%lld, %@" : {
      "comment" : "A value label for the score and the achievement name, used for VoiceOver.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld, %2$@"
          }
        }
      }
    },
